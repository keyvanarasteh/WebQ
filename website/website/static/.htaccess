<IfModule mod_rewrite.c>
    RewriteEngine On

    # Prevent directory listing
    Options -Indexes

    # Force HTTPS (optional but highly recommended)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # --- SvelteKit Routing Rules ---
    
    # If the requested URI is exactly /, serve index.html
    RewriteRule ^$ index.html [L]

    # Remove the .html extension from URLs (Redirect 301 /page.html to /page)
    RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
    RewriteRule ^ /%1 [NC,L,R=301]

    # Map extensionless URLs to their .html counterpart internally
    # (If the requested path is not a directory and appending .html makes it a valid file)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.html -f
    RewriteRule ^(.*)$ $1.html [L]
    
    # Optional SPA-fallback behavior if you had client-side dynamic routes:
    # RewriteCond %{REQUEST_FILENAME} !-f
    # RewriteCond %{REQUEST_FILENAME} !-d
    # RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    
    # SvelteKit immutable assets (JS, CSS, hashed images) reside in _app/immutable/
    # Cache them for 1 year since their filenames change on every build
    <FilesMatch "^.*$">
        SetEnvIf Request_URI "^/_app/immutable/" IMMUTABLE_ASSET
        Header set Cache-Control "public, max-age=31536000, immutable" env=IMMUTABLE_ASSET
    </FilesMatch>

    # Disable caching for index and other non-hashed HTML entries to prevent serving stale versions
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>
