# WebQ Application Configuration

# Tauri / Backend Flags
RUST_LOG=info

# Website & Documentation Deployment (FTP/SSH via deploy_website.sh)
SSH_HOST=192.168.1.100
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=your_secure_password
SSH_TARGET_DIR=/var/www/webq/public_html
WEBSITE_URL=https://webq.example.com
