# WebQ Environment Configuration

# --------------------------
# Website Deployment Configuration
# Used by scripts/deploy_website.sh
# --------------------------
SSH_HOST="your-vps-ip"
SSH_USER="your-username"
SSH_PASSWORD="your-password"
# Ensure the directory contains "webq" for the safety check!
SSH_TARGET_DIR="/path/to/server/webq"
SSH_PORT=22
WEBSITE_URL="https://webq.com"
